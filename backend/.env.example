# ─── server ──────────────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=http://localhost:3000
# Public base URL of THIS backend (used to build /uploads/* URLs in local mode).
PUBLIC_BASE_URL=http://localhost:8080

# ─── auth ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars
ADMIN_USERNAME=damar
ADMIN_PASSWORD=ganti_password_admin_disini

# ─── database ────────────────────────────────────────────────────────
# Local Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/damar_portfolio?sslmode=disable
#
# Supabase (use the "Transaction" pooler — port 6543 — for Cloud Run):
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#
# Or "Session" pooler (port 5432) if you need prepared statements:
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ─── storage ─────────────────────────────────────────────────────────
# "local" (default) writes to UPLOAD_DIR and serves /uploads/* from this server.
# "supabase" uploads to a Supabase Storage bucket (recommended for Cloud Run).
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Required when STORAGE_BACKEND=supabase:
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=ey...        # service_role key — NEVER expose to client
# SUPABASE_BUCKET=portfolio-images
